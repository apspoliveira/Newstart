<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.GymtonicApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/accent_teal</item>
        <item name="colorPrimaryVariant">@color/dark_purple</item>
        <item name="colorOnPrimary">@color/dark_purple</item>

        <!-- Background and Text -->
        <item name="android:windowBackground">@color/dark_purple</item>
        <item name="android:textColor">@color/text_high</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_teal</item>
        <item name="colorOnSecondary">@color/dark_purple</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/dark_purple</item>

        <!-- Control Colors -->
        <item name="colorControlNormal">@color/text_middle</item>
        <item name="colorControlActivated">@color/accent_teal</item>
    </style>
</resources>
