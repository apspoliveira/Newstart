<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_purple">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/textViewAirTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Air (NEWSTART)"
            android:textColor="@color/text_high"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <!-- Item 1: Fresh Air -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/light_purple"
            app:cardCornerRadius="8dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">
                <CheckBox
                    android:id="@+id/checkBoxFreshAir"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Spend time outdoors daily"
                    android:textColor="@color/text_high"
                    android:buttonTint="@color/pop_orange" />
                <com.pierfrancescosoffritti.androidyoutubeplayer.core.player.views.YouTubePlayerView
                    android:id="@+id/youtube_fresh_air"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:enableAutomaticInitialization="false" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Item 2: Ventilation -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/light_purple"
            app:cardCornerRadius="8dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">
                <CheckBox
                    android:id="@+id/checkBoxVentilation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Keep windows open for fresh air"
                    android:textColor="@color/text_high"
                    android:buttonTint="@color/pop_orange" />
                <com.pierfrancescosoffritti.androidyoutubeplayer.core.player.views.YouTubePlayerView
                    android:id="@+id/youtube_ventilation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:enableAutomaticInitialization="false" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Item 3: Deep Breathing -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/light_purple"
            app:cardCornerRadius="8dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">
                <CheckBox
                    android:id="@+id/checkBoxDeepBreathing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Practice deep breathing exercises"
                    android:textColor="@color/text_high"
                    android:buttonTint="@color/pop_orange" />
                <com.pierfrancescosoffritti.androidyoutubeplayer.core.player.views.YouTubePlayerView
                    android:id="@+id/youtube_deep_breathing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:enableAutomaticInitialization="false" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Item 4: Clean Air -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/light_purple"
            app:cardCornerRadius="8dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">
                <CheckBox
                    android:id="@+id/checkBoxCleanAir"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Avoid smoke and polluted areas"
                    android:textColor="@color/text_high"
                    android:buttonTint="@color/pop_orange" />
                <com.pierfrancescosoffritti.androidyoutubeplayer.core.player.views.YouTubePlayerView
                    android:id="@+id/youtube_clean_air"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:enableAutomaticInitialization="false" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
