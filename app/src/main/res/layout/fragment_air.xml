<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_purple">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/textViewAirTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Air (NEWSTART)"
            android:textColor="@color/text_high"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fresh air is essential for life. It purifies the blood and refreshes the body."
            android:textColor="@color/text_middle"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:cardBackgroundColor="@color/light_purple"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daily Goal: 30 mins"
                    android:textColor="@color/text_high"
                    android:textSize="18sp"
                    android:layout_marginBottom="8dp"/>

                <ProgressBar
                    android:id="@+id/progressBarAir"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progress="0"
                    android:max="100"
                    android:progressTint="@color/pop_orange"/>

                <TextView
                    android:id="@+id/textViewAirProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 / 30 mins"
                    android:textColor="@color/text_middle"
                    android:gravity="end"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/buttonAddAir"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Track Fresh Air Time"
            android:backgroundTint="@color/pop_orange"
            android:textColor="@color/white"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NEWSTART Air Principles"
            android:textColor="@color/text_high"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <CheckBox
            android:id="@+id/checkBoxFreshAir"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Spend time outdoors daily"
            android:textColor="@color/text_middle"
            android:buttonTint="@color/pop_orange"
            android:layout_marginBottom="8dp"/>

        <CheckBox
            android:id="@+id/checkBoxVentilation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Keep windows open for fresh air"
            android:textColor="@color/text_middle"
            android:buttonTint="@color/pop_orange"
            android:layout_marginBottom="8dp"/>

        <CheckBox
            android:id="@+id/checkBoxDeepBreathing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Practice deep breathing exercises"
            android:textColor="@color/text_middle"
            android:buttonTint="@color/pop_orange"
            android:layout_marginBottom="8dp"/>

        <CheckBox
            android:id="@+id/checkBoxCleanAir"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Avoid smoke and polluted areas"
            android:textColor="@color/text_middle"
            android:buttonTint="@color/pop_orange"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>
</ScrollView>
